package ui

import "github.com/ProjectBarks/subway-pcb/server/internal/model"

templ EditorPage(user *model.User) {
	@Base("Plugin Editor", user, "/editor") {
		<div id="editor-root" class="h-[calc(100vh-4rem)] flex overflow-hidden"></div>
		<script type="module" src="/static/dist/editor.js"></script>
	}
}
