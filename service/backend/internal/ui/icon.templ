package ui

import "github.com/kaugesaar/lucide-go"

// Icon renders a lucide icon SVG by name with custom class
templ Icon(name string, class string) {
	@templ.Raw(string(lucide.Icon(name, map[string]any{"class": class})))
}

// FilledIcon renders a lucide icon with fill="currentColor" (for brand icons like zap)
templ FilledIcon(name string, class string) {
	@templ.Raw(string(lucide.Icon(name, map[string]any{"class": class, "fill": "currentColor"})))
}
